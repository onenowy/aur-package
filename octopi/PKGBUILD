# Maintainer:
# Contributor: Mark Wagie <mark dot wagie at proton dot me>
# Contributor: MatMoul <matmoul at the google email domain which is .com>

pkgname=octopi
pkgver=0.19.0
pkgrel=4
pkgdesc="A powerful Pacman frontend using Qt libs"
arch=('x86_64')
url="https://github.com/aarnt/octopi"
license=('GPL-2.0-or-later')
depends=(
  'glibc'
  'libgcc'
  'libstdc++'
  'octopi'
  'pacman'
  'pacman-contrib'
  'qt6-base'
  'qt6-multimedia'
  'qtermwidget'
  'qt-sudo'
)
makedepends=(
  'cmake'
  'git'
  'ninja'
  'qt6-5compat'
  'qt6-tools'
  'qt6-svg'
)
optdepends=(
  'inxi: for SysInfo log'
  'lsb-release: for SysInfo log'
  'mhwd: for SysInfo log'
  'pacaur: for AUR support'
  'pacmanlogviewer: to view pacman log files'
  'paru: for AUR support'
  'pikaur: for AUR support'
  'systemd: for SysInfo log'
  'trizen: for AUR support'
  'yay: for AUR support'
)
conflicts=('alpm_octopi_utils')

_commit_alpm=789ba9acc52b7b0624fb08de9f4756b5d51c10f1

source=(
  "$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz"
  "alpm_octopi_utils::git+https://github.com/aarnt/alpm_octopi_utils.git#commit=$_commit_alpm"
)
sha256sums=('bf2f6e2ab6208a020fd34fa6d88eaad5268132c4e38369818fd74267c0c54525'
            '687f3e205cbcfac94e9237049c99ccb88d7cc1ac527c5528cd65ea93b14537fd')

build() {
  # Build alpm_octopi_utils library
  cmake -B build_alpm -S alpm_octopi_utils \
    -G Ninja \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -Wno-dev
  cmake --build build_alpm
  DESTDIR="$srcdir/fakeinstall" cmake --install build_alpm

  # Build octopi using the library built above
  cmake -B build_octopi -S "$pkgname-$pkgver" \
    -G Ninja \
    -DCMAKE_BUILD_TYPE=None \
    -DCMAKE_INSTALL_PREFIX='/usr' \
    -Dalpm_octopi_utils_DIR="$srcdir/fakeinstall/usr/lib/cmake/alpm_octopi_utils/" \
    -Wno-dev
  cmake --build build_octopi
}

package() {
  DESTDIR="$pkgdir" cmake --install build_octopi

  # Install bundled alpm_octopi_utils library
  install -Dm644 "$srcdir/fakeinstall/usr/lib/libalpm_octopi_utils.so" -t "$pkgdir/usr/lib/"

  # Remove licenses directory as it's not strictly necessary for this package's build process
  rm -rf "$pkgdir/usr/share/licenses/"
}
